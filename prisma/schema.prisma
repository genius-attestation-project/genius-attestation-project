generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum LeadStatus {
  New
  Followup
  Assigned
  Pending_Approval
  Closed
  Qualified
  Potential_Qualified
  LOB
}

enum FollowupStatus {
  Pending
  Completed
  Rescheduled
}

enum FollowupActionType {
  Created
  Snoozed
  Completed
  Rescheduled
}

model User {
  id                 String           @id @default(cuid())
  name               String?
  email              String           @unique
  emailVerified      DateTime?
  image              String?
  phone              String?
  passwordHash       String?          @map("password_hash")
  legacyPasswordHash String?          @map("password")
  provider           String?          @default("credentials")
  roleId             String?          @map("role_id")
  role               AccessRole?      @relation(fields: [roleId], references: [id])
  ownerAdminId       String?          @map("owner_admin_id")
  ownerAdmin         User?            @relation("UserOwner", fields: [ownerAdminId], references: [id])
  ownedUsers         User[]           @relation("UserOwner")
  supervisorUserId   String?          @map("supervisor_user_id")
  supervisorRef      User?            @relation("UserSupervisor", fields: [supervisorUserId], references: [id])
  supervisedUsers    User[]           @relation("UserSupervisor")
  createdBy          String?          @map("created_by")
  departmentId       String?          @map("department_id")
  departmentRef      Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  departmentName     String?          @map("department")
  officeLocationId   String?          @map("office_location_id")
  officeLocationRef  OfficeLocation?  @relation(fields: [officeLocationId], references: [id], onDelete: SetNull)
  officeLocationName String?          @map("officeLocation")
  isActive           Boolean          @default(true) @map("is_active")
  lastLoginAt        DateTime?

  accounts           Account[]
  sessions           Session[]
  userRoles          UserRole[]

  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([departmentId])
  @@index([officeLocationId])
  @@index([supervisorUserId])
  @@index([ownerAdminId])
  @@map("users")
}

model Department {
  id           String   @id @default(cuid())
  name         String
  ownerAdminId String   @map("owner_admin_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  users        User[]

  @@unique([name, ownerAdminId])
  @@index([ownerAdminId])
  @@map("departments")
}

model OfficeLocation {
  id           String   @id @default(cuid())
  officeName   String   @map("office_name")
  location     String
  timezone     String
  employees    Int      @default(0)
  ownerAdminId String   @map("owner_admin_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  users        User[]

  @@unique([officeName, ownerAdminId])
  @@index([ownerAdminId])
  @@map("office_locations")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id                    String     @id @default(cuid())
  leadCode              String     @unique
  firstName             String
  lastName              String?
  countryCode           String     @default("+91")
  mobileNumber          String
  email                 String
  docType               String?
  noOfDocuments         Int?
  country               String
  state                 String?
  documentIssuedCountry String?
  service               String
  source                String?
  leadStatus            LeadStatus @default(New)
  clientType            String?
  amount                Decimal    @default(0) @db.Decimal(12, 2)
  workingDays           Int?
  remark                String?
  assignedUser          String?
  assignedUserId        String?    @map("assigned_user_id")
  ownerAdminId          String?    @map("owner_admin_id")
  nextFollowupAt        DateTime?
  followupNotified      Boolean    @default(false) @map("followup_notified")
  followupCompleted     Boolean    @default(false) @map("followup_completed")
  followupStatus        FollowupStatus @default(Pending) @map("followup_status")
  completionDescription String?    @map("completion_description")
  followupCompletionNote String?   @map("followup_completion_note")
  followupCompletedAt    DateTime? @map("followup_completed_at")
  snoozeNote             String?   @map("snooze_note")
  completedAt           DateTime?  @map("completed_at")
  completedBy           String?    @map("completed_by")
  snoozedAt             DateTime?  @map("snoozed_at")
  snoozedBy             String?    @map("snoozed_by")
  closedAt              DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  statusHistory         LeadStatusHistory[]
  assignmentHistory     LeadAssignmentHistory[]
  approvalRequests      LeadStatusApproval[]
  followupHistory       LeadFollowupHistory[]

  @@index([leadStatus])
  @@index([createdAt])
  @@index([service])
  @@index([email])
  @@index([ownerAdminId])
  @@index([assignedUserId])
  @@index([followupStatus])
}

model LeadFollowupHistory {
  id          String             @id @default(cuid())
  leadId       String            @map("lead_id")
  lead         Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actionType   FollowupActionType @map("action_type")
  oldDate      DateTime?         @map("old_date")
  newDate      DateTime?         @map("new_date")
  description  String?
  userId       String?           @map("user_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  ownerAdminId String?           @map("owner_admin_id")

  @@index([leadId])
  @@index([actionType])
  @@index([userId])
  @@index([createdAt])
  @@index([ownerAdminId])
  @@map("lead_followup_history")
}

model LeadStatusHistory {
  id             String     @id @default(cuid())
  leadId         String     @map("lead_id")
  lead           Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  previousStatus LeadStatus @map("previous_status")
  newStatus      LeadStatus @map("new_status")
  changedBy      String?    @map("changed_by")
  ownerAdminId   String?    @map("owner_admin_id")
  createdAt      DateTime   @default(now()) @map("created_at")

  @@index([leadId])
  @@index([newStatus])
  @@index([ownerAdminId])
  @@index([createdAt])
  @@map("lead_status_history")
}

model LeadAssignmentHistory {
  id           String   @id @default(cuid())
  leadId       String   @map("lead_id")
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  oldUserId    String?  @map("old_user_id")
  newUserId    String?  @map("new_user_id")
  changedBy    String?  @map("changed_by")
  ownerAdminId String?  @map("owner_admin_id")
  changedAt    DateTime @default(now()) @map("changed_at")

  @@index([leadId])
  @@index([oldUserId])
  @@index([newUserId])
  @@index([ownerAdminId])
  @@index([changedAt])
  @@map("lead_assignment_history")
}

model LeadStatusApproval {
  id               String     @id @default(cuid())
  leadId           String     @map("lead_id")
  lead             Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  currentStatus    LeadStatus @map("current_status")
  requestedStatus  LeadStatus @map("requested_status")
  requestedBy      String     @map("requested_by")
  supervisorId     String     @map("supervisor_id")
  approvalStatus   String     @default("Pending") @map("approval_status")
  approvalReason   String?    @map("approval_reason")
  rejectionReason  String?    @map("rejection_reason")
  approvedBy       String?    @map("approved_by")
  approvedAt       DateTime?  @map("approved_at")
  ownerAdminId     String?    @map("owner_admin_id")
  createdAt        DateTime   @default(now()) @map("created_at")

  @@index([leadId])
  @@index([supervisorId])
  @@index([requestedBy])
  @@index([approvalStatus])
  @@index([ownerAdminId])
  @@index([createdAt])
  @@map("lead_status_approvals")
}

model Registration {
  id                    String             @id @default(cuid())
  trackingNumber        String             @unique @map("tracking_number")
  customerName          String             @map("customer_name")
  mobile                String
  email                 String?
  address               String?
  country               String?
  state                 String?
  city                  String?
  customerType          String?            @map("customer_type")
  documentType          String?            @map("document_type")
  documentIssuedCountry String?            @map("document_issued_country")
  processType           String?            @map("process_type")
  externalProcess       String?            @map("external_process")
  priority              String?
  committedDuration     String?            @map("committed_duration")
  deliveryLocation      String?            @map("delivery_location")
  totalCharges          Decimal            @default(0) @map("total_charges") @db.Decimal(12, 2)
  advancePaid           Decimal            @default(0) @map("advance_paid") @db.Decimal(12, 2)
  balanceAmount         Decimal            @default(0) @map("balance_amount") @db.Decimal(12, 2)
  balanceReceivedAmount Decimal            @default(0) @map("balance_received_amount") @db.Decimal(12, 2)
  paymentMode           String?            @map("payment_mode")
  paymentStatus         String             @default("Pending") @map("payment_status")
  paymentUpdateStatus   String             @default("Pending") @map("payment_update_status")
  submittedBy           String?            @map("submitted_by")
  submittedAt           DateTime?          @map("submitted_at")
  financeApprovalStatus String             @default("Pending") @map("finance_approval_status")
  approvedBy            String?            @map("approved_by")
  approvedAt            DateTime?          @map("approved_at")
  rejectionReason       String?            @map("rejection_reason")
  collectedPerson       String?            @map("collected_person")
  commissionToUserId    String?            @map("commission_to_user_id")
  commissionToName      String?            @map("commission_to_name")
  commissionToEmail     String?            @map("commission_to_email")
  registeredPerson      String?            @map("registered_person")
  regionOfRegistration  String?            @map("region_of_registration")
  bmStatus              String             @default("Pending") @map("bm_status")
  acceptedBy            String?            @map("accepted_by")
  acceptedAt            DateTime?          @map("accepted_at")
  approvalStatus        String             @default("Pending") @map("approval_status")
  trackingStatus        String             @default("Registered") @map("tracking_status")
  welcomeCallStatus     String             @default("Pending") @map("welcome_call_status")
  welcomeCalledBy       String?            @map("welcome_called_by")
  welcomeCalledAt       DateTime?          @map("welcome_called_at")
  ownerAdminId          String?            @map("owner_admin_id")
  createdBy             String?            @map("created_by")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  files                 RegistrationFile[]
  auditTrail            AuditTrail[]
  paymentUpdates        PaymentUpdate[]
  accountStatementEntries AccountStatementEntry[]

  @@index([ownerAdminId])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([paymentUpdateStatus])
  @@index([approvalStatus])
  @@index([financeApprovalStatus])
  @@index([bmStatus])
  @@index([welcomeCallStatus])
  @@map("registrations")
}

model PaymentUpdate {
  id               String   @id @default(cuid())
  registrationId   String   @map("registration_id")
  registration     Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  trackingNumber   String   @map("tracking_number")
  customerName     String   @map("customer_name")
  processType      String?  @map("process_type")
  totalCharges     Decimal  @default(0) @map("total_charges") @db.Decimal(12, 2)
  advancePaid      Decimal  @default(0) @map("advance_paid") @db.Decimal(12, 2)
  balanceAmount    Decimal  @default(0) @map("balance_amount") @db.Decimal(12, 2)
  paymentMode      String   @map("payment_mode")
  amountPaid       Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)
  invoiceNumber    String   @map("invoice_number")
  paymentDate      DateTime @map("payment_date")
  receiptFileUrl   String?  @map("receipt_file_url")
  receiptFileName  String?  @map("receipt_file_name")
  receiptMimeType  String?  @map("receipt_mime_type")
  receiptFileSize  Int?     @map("receipt_file_size")
  receiptUploadedAt DateTime? @map("receipt_uploaded_at")
  receiptUploadedBy String? @map("receipt_uploaded_by")
  submittedBy      String?  @map("submitted_by")
  submittedAt      DateTime @default(now()) @map("submitted_at")
  approvalStatus   String   @default("Pending") @map("approval_status")
  approvedBy       String?  @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  resetBy          String?  @map("reset_by")
  resetAt          DateTime? @map("reset_at")
  resetReason      String?  @map("reset_reason")
  ownerAdminId     String   @map("owner_admin_id")
  statementEntries AccountStatementEntry[]

  @@index([ownerAdminId])
  @@index([trackingNumber])
  @@index([invoiceNumber])
  @@index([approvalStatus])
  @@index([submittedAt])
  @@map("payment_update")
}

model AccountTransaction {
  id              String   @id @default(cuid())
  transactionType String   @map("transaction_type")
  category        String
  amount          Decimal  @default(0) @db.Decimal(12, 2)
  creditOrDebit   String   @map("credit_or_debit")
  date            DateTime
  description     String?  @map("description")
  voucherNumber   String   @unique @map("voucher_number")
  billFileName    String?  @map("bill_file_name")
  billMimeType    String?  @map("bill_mime_type")
  billFileSize    Int?     @map("bill_file_size")
  billFileData    Bytes?   @map("bill_file_data")
  createdBy       String?  @map("created_by")
  ownerAdminId    String   @map("owner_admin_id")
  createdAt       DateTime @default(now()) @map("created_at")
  statementEntries AccountStatementEntry[]

  @@index([ownerAdminId])
  @@index([creditOrDebit])
  @@index([category])
  @@index([date])
  @@map("account_transactions")
}

model AccountStatementEntry {
  id                   String   @id @default(cuid())
  date                 DateTime
  trackingNumber       String?  @map("tracking_number")
  invoiceNumber        String?  @map("invoice_number")
  voucherNumber        String?  @map("voucher_number")
  particulars          String
  entryType            String   @map("entry_type")
  credit               Decimal  @default(0) @db.Decimal(12, 2)
  debit                Decimal  @default(0) @db.Decimal(12, 2)
  runningBalance       Decimal  @default(0) @map("running_balance") @db.Decimal(12, 2)
  sourceType           String   @map("source_type")
  sourceId             String?  @map("source_id")
  paymentUpdateId      String?  @map("payment_update_id")
  paymentUpdate        PaymentUpdate? @relation(fields: [paymentUpdateId], references: [id], onDelete: SetNull)
  accountTransactionId String?  @map("account_transaction_id")
  accountTransaction   AccountTransaction? @relation(fields: [accountTransactionId], references: [id], onDelete: SetNull)
  registrationId       String?  @map("registration_id")
  registration         Registration? @relation(fields: [registrationId], references: [id], onDelete: SetNull)
  ownerAdminId         String   @map("owner_admin_id")
  createdBy            String?  @map("created_by")
  createdAt            DateTime @default(now()) @map("created_at")
  reversedAt           DateTime? @map("reversed_at")
  reversedBy           String?  @map("reversed_by")
  reversalReason       String?  @map("reversal_reason")

  @@index([ownerAdminId])
  @@index([date])
  @@index([trackingNumber])
  @@index([invoiceNumber])
  @@index([voucherNumber])
  @@index([sourceType, sourceId])
  @@map("account_statement_entries")
}

model RegistrationFile {
  id             String       @id @default(cuid())
  registrationId String       @map("registration_id")
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  fileName       String       @map("file_name")
  mimeType       String       @map("mime_type")
  fileSize       Int          @map("file_size")
  fileData       Bytes        @map("file_data")
  fileCategory   String       @map("file_category")
  uploadedAt     DateTime     @default(now()) @map("uploaded_at")

  @@index([registrationId])
  @@index([fileCategory])
  @@map("registration_files")
}

model AuditTrail {
  id             String       @id @default(cuid())
  registrationId String       @map("registration_id")
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  action         String
  description    String
  performedBy    String?      @map("performed_by")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([registrationId])
  @@index([createdAt])
  @@map("audit_trails")
}

model AccessRole {
  id              String           @id @default(cuid())
  name            String           
  description     String?
  isActive        Boolean          @default(true)
  ownerAdminId    String?          @map("owner_admin_id")
  rolePermissions RolePermission[]
  userRoles       UserRole[]
  users           User[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@unique([name, ownerAdminId])
  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  module          String
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         AccessRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String
  roleId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AccessRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}
